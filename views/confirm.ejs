<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Zertifikatsprüfung</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card card--confirm">
      <section class="page-title-section">
        <h1 class="page-title">Überprüfung des telc Zertifikats</h1>
      </section>

      <section class="status-banner status-banner--success confirm-banner">
        <span class="status-chip status-chip--success">✅ E-Mail bestätigt</span>
        <p class="status-banner__message">
          Vielen Dank! Ihre E-Mail-Adresse wurde erfolgreich bestätigt.
          Die automatische Überprüfung des Zertifikats ist gestartet.
        </p>
      </section>

      <section class="card subcard">
        <p class="subcard__title">Nächster Schritt</p>
        <p class="subcard__text">
          Die Suche nach dem Zertifikat erfolgt alle 4 Stunden.
          Sobald ein Zertifikat gefunden wird, senden wir Ihnen eine weitere E-Mail.
          Den aktuellen Stand sehen Sie jederzeit über Ihren persönlichen Status-Link.
        </p>

        <a class="confirm-cta" href="<%= urlStatus %>">Status jetzt öffnen</a>

        <p class="confirm-url-label">Direkter Status-Link</p>
        <p class="subcard__email confirm-url">
          <a href="<%= urlStatus %>"><%= urlStatus %></a>
        </p>
      </section>

      <section class="card subcard" aria-label="Fortschritt">
        <%- include('partials/current-status', {
          heading: 'Ihr Fortschritt',
          steps: [
            {
              state: 'done',
              title: '1. Anfrage senden',
              text: 'Erledigt: Ihre Anfrage wurde erstellt.',
            },
            {
              state: 'done',
              title: '2. E-Mail bestätigen',
              text: 'Erledigt: Ihre E-Mail-Adresse ist bestätigt.',
            },
            {
              state: 'active',
              title: '3. Automatische Prüfung läuft',
              text: 'Aktiv: Das System prüft alle 4 Stunden automatisch.',
            },
            {
              state: 'todo',
              title: '4. Ergebnis abrufen',
              text: 'Sobald ein Treffer vorliegt, wird der Zertifikat-Link im Status angezeigt.',
            },
          ],
        }) %>
      </section>
    </div>
  </div>
</body>
</html>
