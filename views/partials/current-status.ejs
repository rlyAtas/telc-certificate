<%
  const stepsList = Array.isArray(steps) ? steps : [];

  const stepTitleByNumber = {
    1: {
      todo: 'Anfrage senden',
      active: 'Anfrage senden',
      done: 'Anfrage gesendet',
    },
    2: {
      todo: 'E-Mail-Adresse bestätigen',
      active: 'E-Mail-Adresse bestätigen',
      done: 'E-Mail-Adresse bestätigt',
    },
    3: {
      todo: 'Automatische Prüfung',
      active: 'Automatische Prüfung läuft',
      done: 'Automatische Prüfung abgeschlossen',
    },
    4: {
      todo: 'Ergebnis abrufen',
      active: 'Ergebnis abrufen',
      done: 'Ergebnis erhalten',
    },
  };
%>
<section class="section-card progress-card" aria-label="Fortschritt">
  <p class="subcard__title">Aktueller Stand</p>

  <ol class="flow__list">
    <% stepsList.forEach((item, index) => {
      const rawState = typeof item === 'string' ? item : 'todo';
      const state = rawState === 'done' || rawState === 'active' ? rawState : 'todo';
      const stepNumber = index + 1;
      const autoTitle =
        stepNumber && stepTitleByNumber[stepNumber]
          ? `${stepNumber}. ${stepTitleByNumber[stepNumber][state]}`
          : '';
      const title = autoTitle;
    %>
      <li class="flow__item flow__item--<%= state %>">
        <span class="flow__marker" aria-hidden="true"></span>
        <div>
          <p class="flow__title"><%= title %></p>
        </div>
      </li>
    <% }) %>
  </ol>
</section>
