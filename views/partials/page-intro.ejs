<%
  const icon = typeof introIcon === 'string' && introIcon.trim() ? introIcon : 'ℹ️';
  const label = typeof introLabel === 'string' ? introLabel : '';
  const text = typeof introText === 'string' ? introText : '';
%>
<section class="page-intro">
  <p class="page-intro__title">
    <span aria-hidden="true"><%= icon %></span>
    <% if (label) { %>
      <span><%= label %></span>
    <% } %>
  </p>
  <% if (text) { %>
    <p class="page-intro__message"><%= text %></p>
  <% } %>
</section>
