<%
  const donateUrl = typeof supportDonateUrl === 'string' && supportDonateUrl.trim()
    ? supportDonateUrl
    : 'https://buymeacoffee.com/results.telc';
%>
<section class="section-card support-card">
  <%- include('section-heading', {
    headingIcon: '☕',
    headingText: 'Service unterstützen',
  }) %>

  <p class="support-card__message">
    Wenn der Service Ihnen geholfen hat, können Sie seine Weiterentwicklung mit einer kleinen Spende unterstützen.
  </p>

  <a
    class="support-card__button"
    href="<%= donateUrl %>"
    target="_blank"
    rel="noopener noreferrer"
  >
    Jetzt unterstützen
  </a>
</section>
