<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Zertifikatsprüfung</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card">
      <section class="section-card page-header">
        <h1 class="page-header__title">Überprüfung des telc Zertifikats</h1>
      </section>

      <%- include('partials/page-intro', {
        introIcon: '⚠️',
        introLabel: 'Hinweis',
        introParagraphs: [message],
      }) %>

      <section class="section-card">
        <%- include('partials/section-heading', {
          headingIcon: '🛠️',
          headingText: 'Was können Sie jetzt tun?',
        }) %>
        <p class="subcard__text">
          Prüfen Sie bitte den verwendeten Link und versuchen Sie es erneut.
        </p>
        <a class="confirm-cta" href="/">Zur Startseite</a>
      </section>

      <section class="section-card">
        <%- include('partials/section-heading', {
          headingIcon: '💬',
          headingText: 'Hilfe / Kontakt',
        }) %>
        <% if (supportEmail) { %>
          <p class="subcard__text">
            Wenn das Problem weiterhin besteht, schreiben Sie bitte an:
          </p>
          <p class="subcard__email">
            <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
          </p>
        <% } else { %>
          <p class="subcard__text">
            Wenn das Problem weiterhin besteht, kontaktieren Sie bitte den Support.
          </p>
        <% } %>
      </section>
    </div>
  </div>
</body>
</html>
