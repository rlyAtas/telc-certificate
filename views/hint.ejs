<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Zertifikatsprüfung</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card card--hint">
      <section class="page-title-section">
        <h1 class="page-title">Überprüfung des telc Zertifikats</h1>
      </section>

      <%- include('partials/page-intro', {
        introIcon: '⚠️',
        introLabel: 'Hinweis',
        introText: message,
      }) %>

      <section class="card subcard">
        <p class="subcard__title">Was können Sie jetzt tun?</p>
        <p class="subcard__text">
          Prüfen Sie bitte den verwendeten Link und versuchen Sie es erneut.
        </p>
        <a class="confirm-cta" href="/">Zur Startseite</a>
      </section>

      <section class="card subcard">
        <p class="subcard__title">Hilfe / Kontakt</p>
        <% if (supportEmail) { %>
          <p class="subcard__text">
            Wenn das Problem weiterhin besteht, schreiben Sie bitte an:
          </p>
          <p class="subcard__email">
            <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
          </p>
        <% } else { %>
          <p class="subcard__text">
            Wenn das Problem weiterhin besteht, kontaktieren Sie bitte den Support.
          </p>
        <% } %>
      </section>
    </div>
  </div>
</body>
</html>
