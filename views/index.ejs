<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Zertifikatsprüfung</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card">

      <section class="section-card page-header">
        <h1 class="page-header__title">Überprüfung des telc Zertifikats</h1>
      </section>

      <%- include('partials/page-intro', {
        introIcon: '🔎',
        introLabel: 'Zertifikatsprüfung',
        introParagraphs: ['Dieser Service sucht automatisch nach Ihrem telc-Zertifikat: Er prüft mögliche Prüftermine bis zu 35 Tage lang und informiert Sie sofort, sobald das Zertifikat gefunden wurde.'],
      }) %>

      <%- include('partials/current-status', {
        steps: [
          'active',
          'todo',
          'todo',
          'todo',
        ],
      }) %>

      <form class="section-card home-form" method="post" action="/subscribe" novalidate>
        <%- include('partials/section-heading', {
          headingIcon: '📝',
          headingText: 'Anfrage starten',
        }) %>

        <label class="home-form__label">Teilnehmernummer <span class="home-form__required">*</span></label>
        <input class="home-form__input" name="userNumber" value="<%= values.userNumber || '' %>" />
        <% if (errors.userNumber) { %>
          <div class="home-form__error"><%= errors.userNumber %></div>
        <% } %>

        <label class="home-form__label">Geburtsdatum <span class="home-form__required">*</span></label>
        <input class="home-form__input" type="date" name="birthDate" value="<%= values.birthDate || '' %>" inputmode="numeric"/>
        <% if (errors.birthDate) { %>
          <div class="home-form__error"><%= errors.birthDate %></div>
        <% } %>

        <label class="home-form__label">Prüfungsdatum <span class="home-form__required">*</span></label>
        <input class="home-form__input" type="date" name="examDate" value="<%= values.examDate || '' %>" inputmode="numeric"/>
        <% if (errors.examDate) { %>
          <div class="home-form__error"><%= errors.examDate %></div>
        <% } %>

        <label class="home-form__label">E-Mail-Adresse <span class="home-form__required">*</span></label>
        <input class="home-form__input" type="email" name="email" value="<%= values.email || '' %>" />
        <% if (errors.email) { %>
          <div class="home-form__error"><%= errors.email %></div>
        <% } %>

        <button class="home-form__submit" type="submit">Prüfung starten</button>
      </form>

    </div>
  </div>
</body>
</html>
