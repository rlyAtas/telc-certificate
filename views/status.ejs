<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Status der Anfrage</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card card--status">
      <section class="page-title-section">
        <h1 class="page-title">Überprüfung des telc Zertifikats</h1>
      </section>
      
      <%
        const statusMap = {
          ACTIVE: {
            badge: 'Aktiv',
            icon: '🕒',
            message: 'Die Überprüfung des Zertifikats läuft.',
          },
          CERTIFICATE_FOUND: {
            badge: 'Gefunden',
            icon: '✅',
            message: 'Das Zertifikat wurde gefunden.',
          },
          CHECKING_EXPIRED: {
            badge: 'Abgeschlossen',
            icon: 'ℹ️',
            message: 'Die Überprüfung ist abgeschlossen. Im Prüfzeitraum wurde kein Zertifikat gefunden.',
          },
          CERTIFICATE_FAILED: {
            badge: 'Nicht gefunden',
            icon: '❌',
            message: 'Das Zertifikat konnte innerhalb des Prüfzeitraums nicht gefunden werden.',
          },
        };

        const statusView = statusMap[status] ?? {
          badge: 'Unbekannt',
          icon: 'ℹ️',
          message: 'Der aktuelle Status konnte nicht eindeutig bestimmt werden.',
        };

        const dateFormatter = new Intl.DateTimeFormat('de-DE', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });

        const formatDate = (value) => dateFormatter.format(new Date(value));
        const shouldShowNextCheck = status === 'ACTIVE';
        const nextRunAtIso = nextRunAt ? new Date(nextRunAt).toISOString() : '';
        const initialNextCheckValue = 'wird geplant';

        const lastCheckValueMap = {
          ACTIVE: 'Zertifikat nicht gefunden',
          CERTIFICATE_FOUND: 'Zertifikat gefunden',
          CHECKING_EXPIRED: 'Die Prüfung ist abgeschlossen',
          CERTIFICATE_FAILED: 'Die Prüfung ist abgeschlossen',
        };

        const lastCheckValue = lastCheckValueMap[status] ?? 'Status wird verarbeitet';

        const progressMap = {
          ACTIVE: {
            step1: 'done',
            step2: 'done',
            step3: 'active',
            step4: 'todo',
          },
          CERTIFICATE_FOUND: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
          CHECKING_EXPIRED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
          CERTIFICATE_FAILED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
        };

        const progressView = progressMap[status] ?? {
          step1: 'done',
          step2: 'done',
          step3: 'active',
          step4: 'todo',
        };
      %>

      <%- include('partials/page-intro', {
        introIcon: statusView.icon,
        introLabel: statusView.badge,
        introText: statusView.message,
      }) %>

      <%- include('partials/current-status', {
        steps: [
          progressView.step1,
          progressView.step2,
          progressView.step3,
          progressView.step4,
        ],
      }) %>

      <div class="card subcard status-details">
        <section class="status-details__section">
          <p class="status-details__section-title">Anfrage</p>

          <div class="status-kv">
            <span class="status-kv__label">Prüfungsdatum</span>
            <span class="status-kv__value"><%= formatDate(examDate) %></span>
          </div>

          <% if (finishedAt) { %>
            <div class="status-kv">
              <span class="status-kv__label">Abgeschlossen am</span>
              <span class="status-kv__value"><%= formatDate(finishedAt) %></span>
            </div>
          <% } %>
        </section>

        <section class="status-details__section status-details__section--checks">
          <p class="status-details__section-title">Überprüfung</p>

          <% if (shouldShowNextCheck) { %>
            <p class="status-details__hint">Die Suche nach dem Zertifikat erfolgt alle 4 Stunden.</p>
          <% } %>

          <div class="status-kv">
            <span class="status-kv__label">Letzte Überprüfung</span>
            <span class="status-kv__value"><%= lastCheckValue %></span>
          </div>

          <% if (shouldShowNextCheck) { %>
            <div class="status-kv">
              <span class="status-kv__label">Nächste Überprüfung</span>
              <span
                id="next-check-relative"
                class="status-kv__value status-kv__value--mono status-timer"
                data-next-run-at="<%= nextRunAtIso %>"
              >
                <span class="status-timer__live" data-role="live">
                  <span class="status-timer__prefix" data-role="prefix">in</span>
                  <span data-role="hh">--</span>
                  <span class="status-timer__sep" data-role="sep">:</span>
                  <span data-role="mm">--</span>
                </span>
                <span class="status-timer__text" data-role="text" hidden><%= initialNextCheckValue %></span>
              </span>
            </div>
          <% } %>
        </section>
      </div>
    </div>
  </div>
  <% if (shouldShowNextCheck) { %>
    <script>
      const BLINK_INTERVAL_MS = 500;

      (() => {
        const valueNode = document.getElementById('next-check-relative');
        if (!valueNode) return;
        const liveNode = valueNode.querySelector('[data-role="live"]');
        const textNode = valueNode.querySelector('[data-role="text"]');
        const prefixNode = valueNode.querySelector('[data-role="prefix"]');
        const hhNode = valueNode.querySelector('[data-role="hh"]');
        const sepNode = valueNode.querySelector('[data-role="sep"]');
        const mmNode = valueNode.querySelector('[data-role="mm"]');

        const iso = valueNode.dataset.nextRunAt || '';
        const showText = (message) => {
          if (!liveNode || !textNode) {
            valueNode.textContent = message;
            return;
          }
          liveNode.hidden = true;
          textNode.hidden = false;
          textNode.textContent = message;
        };

        const showTimer = (hours, minutes, blinkOn) => {
          if (!liveNode || !textNode || !prefixNode || !hhNode || !sepNode || !mmNode) {
            return;
          }
          liveNode.hidden = false;
          textNode.hidden = true;
          prefixNode.textContent = 'in';
          hhNode.textContent = String(hours).padStart(2, '0');
          mmNode.textContent = String(minutes).padStart(2, '0');
          sepNode.classList.toggle('status-timer__sep--off', !blinkOn);
        };

        if (!iso) {
          showText('wird geplant');
          return;
        }

        const runAtMs = Date.parse(iso);
        if (Number.isNaN(runAtMs)) {
          showText('wird geplant');
          return;
        }

        const update = () => {
          const diffMs = runAtMs - Date.now();
          if (diffMs <= 0) {
            showText('wird jetzt ausgeführt');
            return;
          }

          const totalMinutes = Math.ceil(diffMs / 60000);
          const hours = Math.floor(totalMinutes / 60);
          const minutes = totalMinutes % 60;
          const blinkOn = Math.floor(Date.now() / BLINK_INTERVAL_MS) % 2 === 0;
          showTimer(hours, minutes, blinkOn);
        };

        update();
        window.setInterval(update, BLINK_INTERVAL_MS);
      })();
    </script>
  <% } %>
</body>
</html>
