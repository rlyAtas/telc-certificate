<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Status der Anfrage</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card">
      <section class="section-card page-header">
        <h1 class="page-header__title">Überprüfung des telc Zertifikats</h1>
      </section>
      
      <%
        const statusMap = {
          ACTIVE: {
            badge: 'Aktiv',
            icon: '🕒',
            message: 'Die Überprüfung des Zertifikats läuft.',
          },
          CERTIFICATE_FOUND: {
            badge: 'Gefunden',
            icon: '✅',
            message: 'Das Zertifikat wurde gefunden.',
          },
          CHECKING_EXPIRED: {
            badge: 'Abgeschlossen',
            icon: 'ℹ️',
            message: 'Die Überprüfung ist abgeschlossen. Im Prüfzeitraum wurde kein Zertifikat gefunden.',
          },
          CERTIFICATE_FAILED: {
            badge: 'Nicht gefunden',
            icon: '❌',
            message: 'Das Zertifikat konnte innerhalb des Prüfzeitraums nicht gefunden werden.',
          },
        };

        const statusView = statusMap[status] ?? {
          badge: 'Unbekannt',
          icon: 'ℹ️',
          message: 'Der aktuelle Status konnte nicht eindeutig bestimmt werden.',
        };

        const progressMap = {
          ACTIVE: {
            step1: 'done',
            step2: 'done',
            step3: 'active',
            step4: 'todo',
          },
          CERTIFICATE_FOUND: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
          CHECKING_EXPIRED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
          CERTIFICATE_FAILED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
          },
        };

        const progressView = progressMap[status] ?? {
          step1: 'done',
          step2: 'done',
          step3: 'active',
          step4: 'todo',
        };

        const safeUserNumber = typeof userNumber === 'string' && userNumber.trim()
          ? userNumber.trim()
          : '-';
        const safeExamDate = typeof examDateText === 'string' && examDateText.trim()
          ? examDateText.trim()
          : '-';
      %>

      <%- include('partials/current-status', {
        steps: [
          progressView.step1,
          progressView.step2,
          progressView.step3,
          progressView.step4,
        ],
      }) %>

      <%- include('partials/page-intro', {
        introIcon: statusView.icon,
        introLabel: statusView.badge,
        introParagraphs: [
          statusView.message,
          `Teilnehmernummer: ${safeUserNumber}`,
          `Prüfungsdatum: ${safeExamDate}`,
        ],
        introUrl: certificateUrl || '',
        introUrlText: certificateUrl ? 'Zertifikat öffnen' : '',
      }) %>

    </div>
  </div>
</body>
</html>
