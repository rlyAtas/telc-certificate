<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>telc – Status der Anfrage</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="wrap">
    <div class="card card--status">
      <h1 class="status-page__title">Status Ihrer Anfrage</h1>

      <%
        const statusMap = {
          ACTIVE: {
            tone: 'active',
            badge: 'Aktiv',
            icon: '🕒',
            message: 'Die Überprüfung des Zertifikats läuft.',
          },
          CERTIFICATE_FOUND: {
            tone: 'success',
            badge: 'Gefunden',
            icon: '✅',
            message: 'Das Zertifikat wurde gefunden.',
          },
          CHECKING_EXPIRED: {
            tone: 'warning',
            badge: 'Abgeschlossen',
            icon: 'ℹ️',
            message: 'Die Überprüfung ist abgeschlossen. Im Prüfzeitraum wurde kein Zertifikat gefunden.',
          },
          CERTIFICATE_FAILED: {
            tone: 'error',
            badge: 'Nicht gefunden',
            icon: '❌',
            message: 'Das Zertifikat konnte innerhalb des Prüfzeitraums nicht gefunden werden.',
          },
        };

        const statusView = statusMap[status] ?? {
          tone: 'neutral',
          badge: 'Unbekannt',
          icon: 'ℹ️',
          message: 'Der aktuelle Status konnte nicht eindeutig bestimmt werden.',
        };

        const dateFormatter = new Intl.DateTimeFormat('de-DE', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });

        const formatDate = (value) => dateFormatter.format(new Date(value));
        const shouldShowNextCheck = status === 'ACTIVE';
        const nextRunAtIso = nextRunAt ? new Date(nextRunAt).toISOString() : '';
        const initialNextCheckValue = nextRunAtIso ? 'wird berechnet...' : 'wird geplant';

        const lastCheckValueMap = {
          ACTIVE: 'Zertifikat nicht gefunden',
          CERTIFICATE_FOUND: 'Zertifikat gefunden',
          CHECKING_EXPIRED: 'Die Prüfung ist abgeschlossen',
          CERTIFICATE_FAILED: 'Die Prüfung ist abgeschlossen',
        };

        const lastCheckValue = lastCheckValueMap[status] ?? 'Status wird verarbeitet';

        const progressMap = {
          ACTIVE: {
            step1: 'done',
            step2: 'done',
            step3: 'active',
            step4: 'todo',
            step3Text: 'Aktiv: Das System prüft den Prüfzeitraum automatisch weiter.',
            step4Title: 'Ergebnis abrufen',
            step4Text: 'Sobald ein Zertifikat gefunden wird, erscheint hier der direkte Link.',
            nextText: 'Wir prüfen automatisch alle 4 Stunden weiter. Sie erhalten zusätzlich eine E-Mail, sobald ein Zertifikat gefunden wurde.',
          },
          CERTIFICATE_FOUND: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
            step3Text: 'Abgeschlossen: Die automatische Prüfung ist beendet.',
            step4Title: 'Zertifikat gefunden',
            step4Text: 'Der direkte Zertifikat-Link ist verfügbar.',
            nextText: 'Die Prüfung ist abgeschlossen. Öffnen Sie Ihr Zertifikat über die Schaltfläche oben.',
          },
          CHECKING_EXPIRED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
            step3Text: 'Abgeschlossen: Die automatische Prüfung ist beendet.',
            step4Title: 'Prüfung abgeschlossen',
            step4Text: 'Im Prüfzeitraum wurde kein Zertifikat gefunden.',
            nextText: 'Die automatische Suche ist beendet. Falls nötig, können Sie eine neue Anfrage starten.',
          },
          CERTIFICATE_FAILED: {
            step1: 'done',
            step2: 'done',
            step3: 'done',
            step4: 'done',
            step3Text: 'Abgeschlossen: Die automatische Prüfung ist beendet.',
            step4Title: 'Prüfung abgeschlossen',
            step4Text: 'Im Prüfzeitraum wurde kein Zertifikat gefunden.',
            nextText: 'Die automatische Suche ist beendet. Falls nötig, können Sie eine neue Anfrage starten.',
          },
        };

        const progressView = progressMap[status] ?? {
          step1: 'done',
          step2: 'done',
          step3: 'active',
          step4: 'todo',
          step3Text: 'Aktiv: Das System prüft den Prüfzeitraum automatisch weiter.',
          step4Title: 'Ergebnis abrufen',
          step4Text: 'Sobald ein Zertifikat gefunden wird, erscheint hier der direkte Link.',
          nextText: 'Die Anfrage wird aktuell verarbeitet. Bitte prüfen Sie den Status erneut.',
        };
      %>

      <section class="status-banner status-banner--<%= statusView.tone %>">
        <span class="status-chip status-chip--<%= statusView.tone %>">
          <%= statusView.icon %> <%= statusView.badge %>
        </span>
        <p class="status-banner__message"><%= statusView.message %></p>
        <% if (certificateUrl) { %>
          <a class="status-cta" href="<%= certificateUrl %>">Zertifikat öffnen</a>
        <% } %>
      </section>

      <section class="card subcard status-flow" aria-label="Fortschritt">
        <p class="subcard__title">Ihr Fortschritt</p>
        <ol class="flow__list">
          <li class="flow__item flow__item--<%= progressView.step1 %>">
            <span class="flow__marker" aria-hidden="true"></span>
            <div>
              <p class="flow__title">1. Anfrage senden</p>
              <p class="flow__text">Erledigt: Ihre Anfrage wurde erstellt.</p>
            </div>
          </li>
          <li class="flow__item flow__item--<%= progressView.step2 %>">
            <span class="flow__marker" aria-hidden="true"></span>
            <div>
              <p class="flow__title">2. E-Mail bestätigen</p>
              <p class="flow__text">Erledigt: Ihre E-Mail-Adresse wurde bestätigt.</p>
            </div>
          </li>
          <li class="flow__item flow__item--<%= progressView.step3 %>">
            <span class="flow__marker" aria-hidden="true"></span>
            <div>
              <p class="flow__title">3. Automatische Prüfung läuft</p>
              <p class="flow__text"><%= progressView.step3Text %></p>
            </div>
          </li>
          <li class="flow__item flow__item--<%= progressView.step4 %>">
            <span class="flow__marker" aria-hidden="true"></span>
            <div>
              <p class="flow__title">4. <%= progressView.step4Title %></p>
              <p class="flow__text"><%= progressView.step4Text %></p>
            </div>
          </li>
        </ol>

        <p class="status-next__title">Was passiert als Nächstes?</p>
        <p class="status-next__text"><%= progressView.nextText %></p>
      </section>

      <div class="card subcard status-details">
        <section class="status-details__section">
          <p class="status-details__section-title">Anfrage</p>

          <div class="status-kv">
            <span class="status-kv__label">Prüfungsdatum</span>
            <span class="status-kv__value"><%= formatDate(examDate) %></span>
          </div>

          <% if (finishedAt) { %>
            <div class="status-kv">
              <span class="status-kv__label">Abgeschlossen am</span>
              <span class="status-kv__value"><%= formatDate(finishedAt) %></span>
            </div>
          <% } %>
        </section>

        <section class="status-details__section status-details__section--checks">
          <p class="status-details__section-title">Überprüfung</p>

          <% if (shouldShowNextCheck) { %>
            <p class="status-details__hint">Die Suche nach dem Zertifikat erfolgt alle 4 Stunden.</p>
          <% } %>

          <div class="status-kv">
            <span class="status-kv__label">Letzte Überprüfung</span>
            <span class="status-kv__value"><%= lastCheckValue %></span>
          </div>

          <% if (shouldShowNextCheck) { %>
            <div class="status-kv">
              <span class="status-kv__label">Nächste Überprüfung</span>
              <span
                id="next-check-relative"
                class="status-kv__value status-kv__value--mono"
                data-next-run-at="<%= nextRunAtIso %>"
              ><%= initialNextCheckValue %></span>
            </div>
          <% } %>
        </section>
      </div>
    </div>
  </div>
  <% if (shouldShowNextCheck) { %>
    <script>
      (() => {
        const valueNode = document.getElementById('next-check-relative');
        if (!valueNode) return;

        const iso = valueNode.dataset.nextRunAt || '';
        if (!iso) {
          valueNode.textContent = 'wird geplant';
          return;
        }

        const runAtMs = Date.parse(iso);
        if (Number.isNaN(runAtMs)) {
          valueNode.textContent = 'wird geplant';
          return;
        }

        const formatNextCheck = (diffMs) => {
          if (diffMs <= 0) {
            return 'wird jetzt ausgeführt';
          }

          const totalMinutes = Math.ceil(diffMs / 60000);
          const hours = Math.floor(totalMinutes / 60);
          const minutes = totalMinutes % 60;

          if (hours > 0 && minutes > 0) {
            return 'in ' + hours + ' Std. ' + minutes + ' Min.';
          }

          if (hours > 0) {
            return 'in ' + hours + ' Std.';
          }

          return 'in ' + minutes + ' Min.';
        };

        const update = () => {
          valueNode.textContent = formatNextCheck(runAtMs - Date.now());
        };

        update();
        window.setInterval(update, 60000);
      })();
    </script>
  <% } %>
</body>
</html>
